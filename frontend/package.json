{
  "name": "frontend-v2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "dev:mock": "VITE_ENABLE_MOCKS=true vite --port 3000",
    "build": "vite build && tsc",
    "prodbuild": "vite build && tsc",
    "serve": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:stack": "playwright test --config playwright.config.stack.ts",
    "test:clean-screenshots": "find tests -path '*/__screenshots__/*' -type f -delete",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "check": "prettier --check . && eslint . --max-warnings 0 && npm run typecheck",
    "fix": "prettier --write . && eslint --fix .",
    "analyze": "vite build --mode analyze",
    "validate:fix": "npm run fix && npm run test:run && npm run test:e2e && npm run build",
    "validate:ci": "npm run check && npm run test:run && npm run test:e2e && npm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dagrejs/dagre": "^3.0.0",
    "@date-fns/tz": "^1.4.1",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.170.4",
    "@tanstack/router-plugin": "^1.168.6",
    "@types/d3-polygon": "^3.0.2",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-polygon": "^3.0.1",
    "date-fns": "^4.1.0",
    "i18next": "^26.2.0",
    "lucide-react": "^1.16.0",
    "lz-string": "^1.5.0",
    "ol": "^10.9.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-force-graph-2d": "^1.29.1",
    "react-globe.gl": "^2.38.0",
    "react-i18next": "^17.0.8",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/eslint-plugin-query": "^5.100.10",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "eslint-plugin-license-header": "^0.9.0",
    "i18next-cli": "^1.57.0",
    "msw": "^2.14.6",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "shadcn": "^4.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "vitest-browser-react": "^2.2.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "volta": {
    "node": "24.15.0",
    "npm": "11.12.1"
  }
}
